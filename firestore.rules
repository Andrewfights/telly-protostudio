rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Prototypes: owner can CRUD, anyone can read if public
    match /prototypes/{prototypeId} {
      allow read: if resource.data.isPublic == true
                  || (request.auth != null && resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && resource.data.ownerId == request.auth.uid;

      // Versions subcollection
      match /versions/{versionId} {
        allow read: if get(/databases/$(database)/documents/prototypes/$(prototypeId)).data.isPublic == true
                    || (request.auth != null && get(/databases/$(database)/documents/prototypes/$(prototypeId)).data.ownerId == request.auth.uid);
        allow write: if request.auth != null
                     && get(/databases/$(database)/documents/prototypes/$(prototypeId)).data.ownerId == request.auth.uid;
      }
    }

    // Zone templates: owner can CRUD, anyone can read if public
    match /zoneTemplates/{templateId} {
      allow read: if resource.data.isPublic == true
                  || (request.auth != null && resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && resource.data.ownerId == request.auth.uid;
    }
  }
}
